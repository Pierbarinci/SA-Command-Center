<script>
// ── CHART DEFAULTS ───────────────────────────────────────────
Chart.defaults.color = '#6b7e94';
Chart.defaults.font.family = "'DM Mono', monospace";
Chart.defaults.font.size = 9;

const gridOpts = {
  color: 'rgba(30,45,66,0.8)',
  drawBorder: false
};

const tickOpts = {
  color: '#6b7e94',
  maxRotation: 0
};

// ── LIVE DATA FROM GOOGLE SHEETS ─────────────────────────────
const SHEET_URL = "https://script.google.com/macros/s/AKfycbz8DfudHauz53BacVTE7CwuRGA3TYE0yh3lNR4nhxZFnWB-urPk9tX2fKF1-kwwrLbiFw/exec";

const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const CY = new Date().getFullYear();
const PY = CY - 1;

// Chart instances — stored so we can update them after data loads
let salesChartInst, feeChartInst, flightsChartInst, aircraftChartInst, hoursChartInst, hoursPerPlaneChartInst;

const BAR_OPTS = () => ({
  responsive: true,
  maintainAspectRatio: true,
  interaction: { mode: 'index', intersect: false },
  plugins: {
    legend: { display: false },
    tooltip: {
      backgroundColor: '#161d2e',
      borderColor: '#1e2d42',
      borderWidth: 1,
      titleColor: '#e8edf4',
      bodyColor: '#6b7e94',
      padding: 10,
      callbacks: {
        label: ctx => ctx.raw !== null && ctx.raw !== undefined ? ` ${ctx.dataset.label}: ${ctx.raw.toLocaleString()}` : null
      }
    }
  },
  scales: {
    x: {
      grid: { display: false },
      ticks: { color: '#6b7e94', maxRotation: 0, font: { size: 9 } },
      border: { color: '#1e2d42' }
    },
    y: {
      grid: { color: 'rgba(30,45,66,0.8)', drawBorder: false },
      ticks: { color: '#6b7e94', font: { size: 9 } },
      border: { display: false }
    }
  },
  animation: { duration: 1000, easing: 'easeInOutQuart' }
});

// ── HELPERS ──────────────────────────────────────────────────
function parseDate(val) {
  if (!val) return null;
  const d = new Date(val);
  return isNaN(d) ? null : d;
}

function fmt$(val) {
  if (val >= 1000000) return '$' + (val/1000000).toFixed(2) + 'M';
  if (val >= 1000)    return '$' + (val/1000).toFixed(0) + 'K';
  return '$' + val.toFixed(0);
}

function buildLabels(maxMonthCY, maxMonthPY) {
  const lastMonth = Math.max(maxMonthCY, maxMonthPY);
  const mLabels = MONTHS.slice(0, lastMonth);
  return [...mLabels, '', 'Full Yr'];
}

function monthArray(n) { return new Array(n).fill(null); }

// ── INIT EMPTY CHARTS ────────────────────────────────────────
function initCharts() {
  const emptyLabels = [...MONTHS, '', 'Full Yr'];

  salesChartInst = new Chart(document.getElementById('salesChart'), {
    type: 'bar',
    data: { labels: emptyLabels, datasets: [
      { label: String(CY), data: [], backgroundColor: 'rgba(90,159,212,0.75)', borderRadius: 2 },
      { label: String(PY), data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 },
      { label: 'FY ' + CY, data: [], backgroundColor: 'rgba(201,151,58,0.85)', borderRadius: 2 },
      { label: 'FY ' + PY, data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 }
    ]},
    options: { ...BAR_OPTS(), scales: { ...BAR_OPTS().scales,
      y: { ...BAR_OPTS().scales.y, ticks: { ...BAR_OPTS().scales.y.ticks, callback: v => v ? '$'+v.toLocaleString() : '' }}}}
  });

  feeChartInst = new Chart(document.getElementById('feeChart'), {
    type: 'bar',
    data: { labels: emptyLabels, datasets: [
      { label: String(CY), data: [], backgroundColor: 'rgba(201,151,58,0.8)',  borderRadius: 2 },
      { label: String(PY), data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 },
      { label: 'FY ' + CY, data: [], backgroundColor: 'rgba(201,151,58,0.9)',  borderRadius: 2 },
      { label: 'FY ' + PY, data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 }
    ]},
    options: { ...BAR_OPTS(), scales: { ...BAR_OPTS().scales,
      y: { ...BAR_OPTS().scales.y, ticks: { ...BAR_OPTS().scales.y.ticks, callback: v => v ? '$'+v.toLocaleString() : '' }}}}
  });

  flightsChartInst = new Chart(document.getElementById('flightsChart'), {
    type: 'bar',
    data: { labels: emptyLabels, datasets: [
      { label: String(CY), data: [], backgroundColor: 'rgba(90,159,212,0.75)', borderRadius: 2 },
      { label: String(PY), data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 },
      { label: 'FY ' + CY, data: [], backgroundColor: 'rgba(201,151,58,0.85)', borderRadius: 2 },
      { label: 'FY ' + PY, data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 }
    ]},
    options: BAR_OPTS()
  });

  hoursChartInst = new Chart(document.getElementById('hoursChart'), {
    type: 'bar',
    data: { labels: emptyLabels, datasets: [
      { label: String(CY), data: [], backgroundColor: 'rgba(90,159,212,0.75)', borderRadius: 2 },
      { label: String(PY), data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 },
      { label: 'FY ' + CY, data: [], backgroundColor: 'rgba(201,151,58,0.85)', borderRadius: 2 },
      { label: 'FY ' + PY, data: [], backgroundColor: 'rgba(58,74,92,0.8)',    borderRadius: 2 }
    ]},
    options: { ...BAR_OPTS(), scales: { ...BAR_OPTS().scales,
      y: { ...BAR_OPTS().scales.y, ticks: { ...BAR_OPTS().scales.y.ticks, callback: v => v ? v+'h' : '' }}}}
  });

  aircraftChartInst = new Chart(document.getElementById('aircraftChart'), {
    type: 'bar',
    data: { labels: [], datasets: [{ label: 'Flights YTD', data: [],
      backgroundColor: ['rgba(201,151,58,0.85)','rgba(201,151,58,0.75)','rgba(201,151,58,0.65)',
        'rgba(58,127,193,0.75)','rgba(58,127,193,0.65)','rgba(58,127,193,0.5)'],
      borderRadius: 2 }]},
    options: { ...BAR_OPTS(), plugins: { ...BAR_OPTS().plugins, tooltip: {
      ...BAR_OPTS().plugins.tooltip, callbacks: { label: ctx => ` ${ctx.raw} flights` }}}}
  });

  hoursPerPlaneChartInst = new Chart(document.getElementById('hoursPerPlaneChart'), {
    type: 'bar',
    data: { labels: [], datasets: [{ label: 'Hours YTD', data: [],
      backgroundColor: ['rgba(201,151,58,0.85)','rgba(201,151,58,0.75)','rgba(201,151,58,0.65)',
        'rgba(58,127,193,0.75)','rgba(58,127,193,0.65)','rgba(58,127,193,0.5)'],
      borderRadius: 2 }]},
    options: { ...BAR_OPTS(), scales: { ...BAR_OPTS().scales,
      x: { ...BAR_OPTS().scales.x, ticks: { color: '#6b7e94', maxRotation: 30, font: { size: 8 }}},
      y: { ...BAR_OPTS().scales.y, ticks: { ...BAR_OPTS().scales.y.ticks, callback: v => v ? v+'h' : '' }}},
      plugins: { ...BAR_OPTS().plugins, tooltip: {
        ...BAR_OPTS().plugins.tooltip, callbacks: { label: ctx => ` ${ctx.raw}h flown` }}}}
  });
}

// ── PROCESS DATA ─────────────────────────────────────────────
function processData(rows) {
  // Monthly buckets
  const salesMoCY   = new Array(12).fill(0);
  const salesMoPY   = new Array(12).fill(0);
  const feeMoCY     = new Array(12).fill(0);
  const feeMoPY     = new Array(12).fill(0);
  const flightsMoCY = new Array(12).fill(0);
  const flightsMoPY = new Array(12).fill(0);
  const hoursMoCY   = new Array(12).fill(0);
  const hoursMoPY   = new Array(12).fill(0);

  // Totals
  let salesTotalCY = 0, salesTotalPY = 0;
  let feeTotalCY   = 0, feeTotalPY   = 0;
  let flightsTotalCY = 0, flightsTotalPY = 0;
  let hoursTotalCY = 0,  hoursTotalPY = 0;

  // Aggregations
  const aircraftFlights = {};
  const aircraftHours   = {};
  const routeFlights    = {};

  let maxMonthCY = 0, maxMonthPY = 0;

  rows.forEach(row => {
    const status = (row['Flight Status'] || '').toString().trim().toLowerCase();
    if (status === 'cancelled' || status === 'canceled') return;

    const dateVal = row['Departure Date'] || row['Invoice Date'];
    const d = parseDate(dateVal);
    if (!d) return;

    const yr  = d.getFullYear();
    const mo  = d.getMonth(); // 0-indexed

    const cost     = parseFloat((row[' Flight Cost '] || row['Flight Cost'] || '0').toString().replace(/[$,]/g,'')) || 0;
    const comm     = parseFloat((row['Commission $'] || '0').toString().replace(/[$,]/g,'')) || 0;
    const hrs      = parseFloat((row['Flight Hours'] || '0').toString().replace(/[,]/g,'')) || 0;
    const aircraft = (row['Aircraft'] || 'Unknown').toString().trim();
    const from     = (row['From'] || '').toString().trim().toUpperCase();
    const to       = (row['To'] || '').toString().trim().toUpperCase();
    const route    = from && to ? from + ' → ' + to : null;

    if (yr === CY) {
      salesMoCY[mo]   += cost;
      feeMoCY[mo]     += comm;
      flightsMoCY[mo] += 1;
      hoursMoCY[mo]   += hrs;
      salesTotalCY    += cost;
      feeTotalCY      += comm;
      flightsTotalCY  += 1;
      hoursTotalCY    += hrs;
      if (mo > maxMonthCY) maxMonthCY = mo;

      // Aircraft
      if (!aircraftFlights[aircraft]) { aircraftFlights[aircraft] = 0; aircraftHours[aircraft] = 0; }
      aircraftFlights[aircraft] += 1;
      aircraftHours[aircraft]   += hrs;

      // Routes
      if (route) {
        if (!routeFlights[route]) routeFlights[route] = 0;
        routeFlights[route] += 1;
      }
    } else if (yr === PY) {
      salesMoPY[mo]   += cost;
      feeMoPY[mo]     += comm;
      flightsMoPY[mo] += 1;
      hoursMoPY[mo]   += hrs;
      salesTotalPY    += cost;
      feeTotalPY      += comm;
      flightsTotalPY  += 1;
      hoursTotalPY    += hrs;
      if (mo > maxMonthPY) maxMonthPY = mo;
    }
  });

  const lastMo = Math.max(maxMonthCY, maxMonthPY) + 1; // +1 to include the last month
  const mLabels = [...MONTHS.slice(0, lastMo), '', 'Full Yr'];

  // Build chart arrays (month data + spacer null + full year total)
  function buildArr(monthly, total, n) {
    const arr = monthly.slice(0, n).map(v => v > 0 ? Math.round(v) : null);
    return [...arr, null, Math.round(total) || null];
  }

  // ── UPDATE CHARTS ─────────────────────────────────────────
  function updateChart(chart, labels, datasets) {
    chart.data.labels = labels;
    datasets.forEach((d, i) => { chart.data.datasets[i].data = d; });
    chart.update();
  }

  updateChart(salesChartInst, mLabels, [
    buildArr(salesMoCY,  salesTotalCY, lastMo),
    buildArr(salesMoPY,  salesTotalPY, lastMo),
    [...new Array(lastMo).fill(null), null, Math.round(salesTotalCY) || null],
    [...new Array(lastMo).fill(null), null, Math.round(salesTotalPY) || null]
  ]);

  updateChart(feeChartInst, mLabels, [
    buildArr(feeMoCY,  feeTotalCY, lastMo),
    buildArr(feeMoPY,  feeTotalPY, lastMo),
    [...new Array(lastMo).fill(null), null, Math.round(feeTotalCY) || null],
    [...new Array(lastMo).fill(null), null, Math.round(feeTotalPY) || null]
  ]);

  updateChart(flightsChartInst, mLabels, [
    buildArr(flightsMoCY, flightsTotalCY, lastMo),
    buildArr(flightsMoPY, flightsTotalPY, lastMo),
    [...new Array(lastMo).fill(null), null, flightsTotalCY || null],
    [...new Array(lastMo).fill(null), null, flightsTotalPY || null]
  ]);

  updateChart(hoursChartInst, mLabels, [
    buildArr(hoursMoCY, hoursTotalCY, lastMo),
    buildArr(hoursMoPY, hoursTotalPY, lastMo),
    [...new Array(lastMo).fill(null), null, Math.round(hoursTotalCY*10)/10 || null],
    [...new Array(lastMo).fill(null), null, Math.round(hoursTotalPY*10)/10 || null]
  ]);

  // Aircraft charts — sorted by flights desc
  const acSorted = Object.keys(aircraftFlights).sort((a,b) => aircraftFlights[b] - aircraftFlights[a]).slice(0,8);
  aircraftChartInst.data.labels = acSorted;
  aircraftChartInst.data.datasets[0].data = acSorted.map(a => aircraftFlights[a]);
  aircraftChartInst.update();

  hoursPerPlaneChartInst.data.labels = acSorted;
  hoursPerPlaneChartInst.data.datasets[0].data = acSorted.map(a => Math.round(aircraftHours[a]*10)/10);
  hoursPerPlaneChartInst.update();

  // ── UPDATE KPI CARDS ───────────────────────────────────────
  const feeP = salesTotalCY > 0 ? (feeTotalCY / salesTotalCY * 100).toFixed(1) : '0.0';
  const salesChg = salesTotalPY > 0 ? ((salesTotalCY - salesTotalPY)/salesTotalPY*100).toFixed(0) : null;
  const feeChg   = feeTotalPY   > 0 ? ((feeTotalCY   - feeTotalPY)  /feeTotalPY  *100).toFixed(0) : null;

  document.querySelector('.kpi-val.gold').textContent = fmt$(salesTotalCY);
  document.querySelector('.kpi-val.sky').textContent  = fmt$(feeTotalCY);
  document.querySelector('.kpi-val.green').textContent = feeP + '%';

  if (salesChg !== null) {
    const badge = document.querySelector('.kpi-val.gold').nextElementSibling.querySelector('.kpi-badge');
    if (badge) { badge.textContent = (salesChg >= 0 ? '+' : '') + salesChg + '%'; badge.className = 'kpi-badge ' + (salesChg >= 0 ? 'up' : 'down'); }
    document.querySelector('.kpi-val.gold').nextElementSibling.childNodes[0].textContent = 'vs ' + fmt$(salesTotalPY) + ' prior year ';
  }
  if (feeChg !== null) {
    const badge2 = document.querySelector('.kpi-val.sky').nextElementSibling.querySelector('.kpi-badge');
    if (badge2) { badge2.textContent = (feeChg >= 0 ? '+' : '') + feeChg + '%'; badge2.className = 'kpi-badge ' + (feeChg >= 0 ? 'up' : 'down'); }
    document.querySelector('.kpi-val.sky').nextElementSibling.childNodes[0].textContent = 'vs ' + fmt$(feeTotalPY) + ' prior year ';
  }

  // ── UPDATE BANNER YEAR ─────────────────────────────────────
  const lastMonthName = MONTHS[maxMonthCY] || '';
  document.querySelector('.banner-year').textContent = 'FY ' + CY + ' · YTD through ' + lastMonthName;

  // ── UPDATE ROUTE RANKINGS ──────────────────────────────────
  const routeSorted = Object.keys(routeFlights).sort((a,b) => routeFlights[b] - routeFlights[a]).slice(0,12);
  const maxRouteFlights = routeSorted.length > 0 ? routeFlights[routeSorted[0]] : 1;
  const routeEl = document.getElementById('routeChart');
  routeEl.innerHTML = routeSorted.map(route => {
    const cnt = routeFlights[route];
    const pct = Math.round(cnt / maxRouteFlights * 100);
    const isIntl = !['MIA','TPA','JFK','LAX','ORD','ATL','DFW','BOS','MIA','FLL','MCO','PBI'].some(d => route.includes(d) && route.split('→').every(p => ['MIA','TPA','JFK','LAX','ORD','ATL','DFW','BOS','FLL','MCO','PBI','EYW','SJU'].includes(p.trim())));
    const color = pct === 100 ? 'linear-gradient(90deg,#c9973a,#e8b84e)' : pct > 60 ? 'linear-gradient(90deg,#b8862a,#d4a440)' : 'linear-gradient(90deg,#3a7fc1,#5a9fd4)';
    return \`<div class="route-item">
      <div class="route-label">\${route}</div>
      <div class="route-bar-wrap"><div class="route-bar" data-val="\${cnt}" style="width:\${pct}%;background:\${color}"></div></div>
      <div class="route-count">\${cnt}</div>
    </div>\`;
  }).join('');
}

// ── FETCH & LOAD ─────────────────────────────────────────────
function showLoading() {
  document.querySelector('.kpi-val.gold').textContent  = '...';
  document.querySelector('.kpi-val.sky').textContent   = '...';
  document.querySelector('.kpi-val.green').textContent = '...';
}

function showError(msg) {
  document.querySelector('.kpi-val.gold').textContent  = 'Error';
  document.querySelector('.kpi-val.sky').textContent   = 'Error';
  document.querySelector('.kpi-val.green').textContent = msg;
}

async function loadData() {
  showLoading();
  try {
    const res = await fetch(SHEET_URL);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const rows = await res.json();
    if (!Array.isArray(rows)) throw new Error('Invalid data format');
    processData(rows);
  } catch(err) {
    console.error('Dashboard data error:', err);
    showError('Load failed');
  }
}

// ── BOOT ─────────────────────────────────────────────────────
initCharts();
loadData();

// Auto-refresh every 5 minutes
setInterval(loadData, 5 * 60 * 1000);

</script>
