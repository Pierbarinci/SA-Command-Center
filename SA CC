<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Salas Aviation — Operations Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg:       #0b0f17;
  --surface:  #111827;
  --card:     #161d2e;
  --border:   #1e2d42;
  --gold:     #c9973a;
  --gold-lt:  #e8b84e;
  --gold-dim: rgba(201,151,58,0.15);
  --sky:      #3a7fc1;
  --sky-lt:   #5a9fd4;
  --sky-dim:  rgba(58,127,193,0.15);
  --green:    #2a9d6f;
  --red:      #c94a3a;
  --text:     #e8edf4;
  --muted:    #6b7e94;
  --dim:      #3a4a5c;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Barlow', sans-serif;
  font-weight: 300;
  min-height: 100vh;
}

/* ── BANNER ─────────────────────────────────────────── */
.banner {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 64px;
  position: sticky;
  top: 0;
  z-index: 100;
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.banner-icon {
  width: 36px;
  height: 36px;
  background: var(--gold-dim);
  border: 1px solid rgba(201,151,58,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.banner-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px;
  letter-spacing: 0.12em;
  color: var(--gold-lt);
  line-height: 1;
}

.banner-sub {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.22em;
  color: var(--muted);
  text-transform: uppercase;
  margin-top: 2px;
}

.banner-right {
  display: flex;
  align-items: center;
  gap: 20px;
}

.banner-year {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.14em;
  color: var(--muted);
  border: 1px solid var(--border);
  padding: 5px 14px;
}

.banner-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px var(--green);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%,100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ── LAYOUT ─────────────────────────────────────────── */
.dash {
  padding: 24px 28px 40px;
  max-width: 1440px;
  margin: 0 auto;
}

.row { display: flex; gap: 16px; margin-bottom: 16px; }
.row.three > * { flex: 1; }
.row.two   > * { flex: 1; }
.row.full  > * { flex: 1; }

/* ── CARD ───────────────────────────────────────────── */
.card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 20px 22px;
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.5s ease both;
}

.card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}

.card.gold-accent::before  { background: linear-gradient(90deg, var(--gold), transparent); }
.card.sky-accent::before   { background: linear-gradient(90deg, var(--sky), transparent); }
.card.green-accent::before { background: linear-gradient(90deg, var(--green), transparent); }

@keyframes fadeUp {
  from { opacity:0; transform:translateY(12px); }
  to   { opacity:1; transform:translateY(0); }
}

/* ── KPI CARD ───────────────────────────────────────── */
.kpi-label {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
}

.kpi-val {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 46px;
  letter-spacing: 0.04em;
  line-height: 1;
  margin-bottom: 6px;
}

.kpi-val.gold  { color: var(--gold-lt); }
.kpi-val.sky   { color: var(--sky-lt); }
.kpi-val.green { color: #4ecb9e; }

.kpi-sub {
  font-size: 11px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 6px;
}

.kpi-badge {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  padding: 2px 7px;
  border-radius: 2px;
}

.kpi-badge.up   { background: rgba(42,157,111,0.15); color: #4ecb9e; }
.kpi-badge.down { background: rgba(201,74,58,0.15);  color: #e87060; }

.kpi-sparkline {
  position: absolute;
  bottom: 0; right: 0;
  opacity: 0.12;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 80px;
  line-height: 1;
  color: var(--gold);
  pointer-events: none;
}

/* ── CHART CARD ─────────────────────────────────────── */
.chart-title {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 4px;
}

.chart-heading {
  font-family: 'Barlow', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.legend {
  display: flex;
  gap: 14px;
  align-items: center;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.1em;
  color: var(--muted);
}

.legend-dot {
  width: 8px; height: 8px;
  border-radius: 1px;
  flex-shrink: 0;
}

.chart-wrap {
  position: relative;
}

/* ── MAP SECTION ────────────────────────────────────── */
.map-card {
  background: var(--card);
  border: 1px solid var(--border);
  padding: 20px 22px;
  animation: fadeUp 0.5s 0.3s ease both;
}

.map-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--gold), var(--sky), transparent);
}

#leafletMap {
  width: 100%;
  height: 320px;
  position: relative;
  background: var(--bg);
  border: 1px solid var(--border);
  overflow: hidden;
}

/* ── ROUTE BAR ──────────────────────────────────────── */
.route-item {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 8px;
}

.route-label {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--text);
  width: 90px;
  flex-shrink: 0;
  font-weight: 500;
}

.route-bar-wrap {
  flex: 1;
  height: 20px;
  background: rgba(255,255,255,0.04);
  border-radius: 1px;
  overflow: hidden;
  position: relative;
}

.route-bar {
  height: 100%;
  border-radius: 1px;
  transition: width 1s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
}

.route-bar::after {
  content: attr(data-val);
  position: absolute;
  right: 8px;
  top: 50%;
  transform: translateY(-50%);
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  color: rgba(0,0,0,0.7);
  font-weight: 500;
}

.route-count {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--muted);
  width: 30px;
  text-align: right;
  flex-shrink: 0;
}

/* section divider */
.section-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
  margin-top: 8px;
}

.section-divider span {
  font-family: 'DM Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  white-space: nowrap;
}

.section-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

</style>
</head>
